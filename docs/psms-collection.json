          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/api/admin/import/templates/citizens"
          }
        },
        {
          "name": "Import Citizens CSV",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/api/admin/import/citizens",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Rate Limit Test",
      "item": [
        {
          "name": "Brute Force Login (expect 429)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"wrong@example.com\",\n  \"password\": \"wrong\"\n}"
            },
            "description": "Gửi request này nhiều lần (>10 lần trong 1 phút) → expect 429 Too Many Requests với header Retry-After"
          }
        }
      ]
    }
  ]
}

