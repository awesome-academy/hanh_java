            "url": "{{base_url}}/api/admin/services/1/toggle"
          }
        }
      ]
    },
    {
      "name": "Admin — Departments",
      "item": [
        {
          "name": "List Departments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/api/admin/departments"
          }
        },
        {
          "name": "Create Department",
          "request": {
