            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/admin/departments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"PB-010\",\n  \"name\": \"Phòng Quản lý Đô thị\",\n  \"phone\": \"02812345678\",\n  \"email\": \"pb010@psms.local\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin — Staff",
      "item": [
        {
          "name": "List Staff",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/admin/staff?page=0&size=20",
              "query": [
                { "key": "departmentId", "value": "", "disabled": true },
                { "key": "isAvailable", "value": "", "disabled": true },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin — Activity Log",
      "item": [
        {
          "name": "Get Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/admin/logs?page=0&size=50",
              "query": [
                { "key": "action", "value": "", "disabled": true },
                { "key": "userId", "value": "", "disabled": true },
                { "key": "from", "value": "", "disabled": true },
                { "key": "to", "value": "", "disabled": true },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Purge Old Logs (SUPER_ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/admin/logs/purge?days=90",
              "query": [{ "key": "days", "value": "90" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin — CSV Import/Export",
      "item": [
        {
          "name": "Export Citizens CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/api/admin/export/citizens"
          }
